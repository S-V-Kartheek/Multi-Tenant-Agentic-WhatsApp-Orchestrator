# ─────────────────────────────────────────────────────────────────────────────
# gcp/secrets.env.example — Template for creating GCP Secret Manager secrets
#
# Usage (run each line in your terminal after `gcloud auth login`):
#   export PROJECT_ID="YOUR_PROJECT_ID"
#   Then run the commands below, replacing <VALUE> with actual values.
#
# Or use gcp/setup.sh which handles all of this interactively.
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Format: mongodb+srv://username:password@cluster.mongodb.net/whatsapp_agent
echo -n "mongodb+srv://user:pass@cluster.mongodb.net/whatsapp_agent" | \
  gcloud secrets create MONGO_URI --data-file=- --project=$PROJECT_ID

# ── Google Gemini ─────────────────────────────────────────────────────────────
echo -n "AIzaSy..." | \
  gcloud secrets create GEMINI_API_KEY --data-file=- --project=$PROJECT_ID

# ── Meta Webhook Verification ─────────────────────────────────────────────────
# Set this to any random string — you'll paste it into Meta App Dashboard too
echo -n "my_custom_verify_token_123" | \
  gcloud secrets create META_VERIFY_TOKEN --data-file=- --project=$PROJECT_ID

# ── Meta App Secret (for X-Hub-Signature-256 webhook security) ───────────────
echo -n "abc123..." | \
  gcloud secrets create META_APP_SECRET --data-file=- --project=$PROJECT_ID

# ── Tenant A — Luxury Furniture ───────────────────────────────────────────────
echo -n "123456789012345" | \
  gcloud secrets create META_PHONE_NUMBER_ID_TENANT_A --data-file=- --project=$PROJECT_ID

echo -n "EAAxxxxxxxxxx..." | \
  gcloud secrets create META_WHATSAPP_TOKEN_TENANT_A --data-file=- --project=$PROJECT_ID

# ── Tenant B — Automotive Care ────────────────────────────────────────────────
echo -n "987654321098765" | \
  gcloud secrets create META_PHONE_NUMBER_ID_TENANT_B --data-file=- --project=$PROJECT_ID

echo -n "EAAyyyyyyyyyyy..." | \
  gcloud secrets create META_WHATSAPP_TOKEN_TENANT_B --data-file=- --project=$PROJECT_ID

# ─────────────────────────────────────────────────────────────────────────────
# To UPDATE an existing secret value:
#   echo -n "new_value" | gcloud secrets versions add SECRET_NAME --data-file=-
#
# To VIEW a secret (for debugging):
#   gcloud secrets versions access latest --secret=SECRET_NAME
#
# To LIST all secrets:
#   gcloud secrets list --project=$PROJECT_ID
# ─────────────────────────────────────────────────────────────────────────────
