# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT ONLY
# In production (GCP Cloud Run), all secrets are loaded from GCP Secret Manager.
# See: gcp/setup.sh and gcp/secrets.env.example
#
# Usage: cp .env.example .env  →  then fill in real values
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────
# MongoDB
# ─────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/whatsapp_agent?retryWrites=true&w=majority
MONGO_DB_NAME=whatsapp_agent

# ─────────────────────────────────────────────────────
# Google Gemini
# ─────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSy...

# ─────────────────────────────────────────────────────
# Twilio WhatsApp API
# Get these from: https://console.twilio.com
# ─────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Twilio Sandbox Number (both tenants share this during testing)
# Format MUST include the "whatsapp:" prefix
# Default sandbox number is: whatsapp:+14155238886
TWILIO_WHATSAPP_NUMBER_TENANT_A=whatsapp:+14155238886
TWILIO_WHATSAPP_NUMBER_TENANT_B=whatsapp:+14155238886

# ─────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
